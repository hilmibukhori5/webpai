# Template .env untuk server Plesk (httpdocs/pendaftaran-pai-app/.env).
# File ini CONTOH saja (boleh di-commit) -- .env asli yang asli TIDAK ikut
# git (lihat .gitignore), jadi harus dibuat manual di server lewat File
# Manager, isi nilai PLACEHOLDER di bawah dengan punya kamu sendiri.
#
# Cuma baris yang beda dari .env biasa/lokal yang dikomentari -- selebihnya
# sama kayak .env.example yang sudah ada di root project.

APP_NAME="Pendaftaran PAI"
APP_ENV=production
APP_KEY=                          # generate lokal: php artisan key:generate --show, paste hasilnya di sini
APP_DEBUG=false
APP_URL=https://math.ub.ac.id/pendaftaran-pai

ASSET_URL=https://math.ub.ac.id/pendaftaran-pai

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                   # production: jangan "debug", terlalu berisik & bisa leak info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1                 # isi sesuai info DB yang dibuatkan Plesk (Databases panel)
DB_PORT=3306
DB_DATABASE=                      # PLACEHOLDER
DB_USERNAME=                      # PLACEHOLDER
DB_PASSWORD=                      # PLACEHOLDER

# Kalau plan hosting cuma kasih 1 database per domain (jadi DB_DATABASE di
# atas KE DATABASE YANG SAMA dengan Laravel #1): WAJIB isi DB_PREFIX biar
# semua tabel project ini (termasuk tabel "migrations"-nya sendiri) gak
# collision sama tabel Laravel #1 yang sudah ada di database itu. Kosongkan
# baris ini kalau memang punya database sendiri yang terpisah.
DB_PREFIX=paipendaftaran_

# Cookie session DIBEDAKAN biar gak bentrok sama Laravel #1 (domain sama:
# math.ub.ac.id). SESSION_PATH di-scope ke subfolder ini juga (bukan wajib,
# tapi lebih rapi -- cookie cuma kekirim buat request ke /pendaftaran-pai/*).
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/pendaftaran-pai
SESSION_DOMAIN=null
SESSION_COOKIE=pendaftaran_pai_session

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# QUEUE_CONNECTION=sync (BUKAN database) -- karena server Plesk ini gak ada
# cara jalanin `php artisan queue:work` terus-menerus (gak ada shell
# persisten/cron yang dikonfirmasi tersedia). Mailable ApprovedModule &
# RejectedModule (implements ShouldQueue) otomatis tetap jalan, cuma
# eksekusinya langsung inline saat request (admin klik Setujui/Tolak nunggu
# dikit lebih lama nunggu SMTP, bukan dilempar ke job queue). Kalau nanti
# ternyata ada akses Scheduled Tasks/cron, boleh balik ke `database` +
# jadwalkan `php artisan queue:work --stop-when-empty` tiap menit.
QUEUE_CONNECTION=sync

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=                    # PLACEHOLDER -- JANGAN commit nilai aslinya kemanapun
MAIL_PASSWORD=                    # PLACEHOLDER (Gmail App Password)
MAIL_FROM_ADDRESS=                # PLACEHOLDER
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
